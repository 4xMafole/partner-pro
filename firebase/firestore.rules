rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isResourceOwner() {
      return isSignedIn() && isOwner(resource.data.user_id);
    }

    function isAgent() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'agent';
    }

    match /users/{userId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/favorites/{document} {
      allow create, read, update, delete: if isOwner(userId);
    }

    match /users/{userId}/offer/{document} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /users/{userId}/suggestions/{document} {
      allow create, read, update, delete: if isOwner(userId);
    }

    match /users/{userId}/showami/{document} {
      allow create, read, update, delete: if isOwner(userId);
    }

    match /favorites/{document} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if isResourceOwner();
    }

    match /{path=**}/favorites/{document} {
      allow read: if isResourceOwner();
    }

    match /{path=**}/suggestions/{document} {
      allow read: if isResourceOwner();
    }

    match /{path=**}/showami/{document} {
      allow read: if isResourceOwner();
    }

    match /properties/{document} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAgent() || request.resource.data.user_id == request.auth.uid);
      allow update: if isResourceOwner() || isAgent();
      allow delete: if isResourceOwner();
    }

    match /notifications/{document} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && resource.data.recipient_id == request.auth.uid;
      allow delete: if false;
    }

    match /invitations/{document} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
                     (resource.data.sender_id == request.auth.uid ||
                      resource.data.recipient_id == request.auth.uid);
      allow update: if isSignedIn() && resource.data.recipient_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.sender_id == request.auth.uid;
    }

    match /relationships/{document} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() &&
                                     (resource.data.buyer_id == request.auth.uid ||
                                      resource.data.agent_id == request.auth.uid);
    }

    match /support/{document} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read, update: if isResourceOwner();
      allow delete: if false;
    }

    match /saved_searches/{document} {
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if isResourceOwner();
    }

    match /showings/{document} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() &&
                             (resource.data.buyer_id == request.auth.uid ||
                              resource.data.agent_id == request.auth.uid ||
                              resource.data.seller_id == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.buyer_id == request.auth.uid;
    }

    match /offer/{offerId} {
      allow create: if isSignedIn() && request.resource.data.buyer_id == request.auth.uid;
      allow read, update: if isSignedIn() &&
                             (resource.data.buyer_id == request.auth.uid ||
                              resource.data.buyer_agent_id == request.auth.uid ||
                              resource.data.seller_id == request.auth.uid ||
                              resource.data.seller_agent_id == request.auth.uid);
      allow delete: if false;

      match /revisions/{revisionId} {
        allow read: if isSignedIn() &&
                       (get(/databases/$(database)/documents/offer/$(offerId)).data.buyer_id == request.auth.uid ||
                        get(/databases/$(database)/documents/offer/$(offerId)).data.buyer_agent_id == request.auth.uid ||
                        get(/databases/$(database)/documents/offer/$(offerId)).data.seller_id == request.auth.uid ||
                        get(/databases/$(database)/documents/offer/$(offerId)).data.seller_agent_id == request.auth.uid);
        allow create: if isSignedIn() &&
                        (get(/databases/$(database)/documents/offer/$(offerId)).data.buyer_id == request.auth.uid ||
                         get(/databases/$(database)/documents/offer/$(offerId)).data.buyer_agent_id == request.auth.uid ||
                         get(/databases/$(database)/documents/offer/$(offerId)).data.seller_id == request.auth.uid ||
                         get(/databases/$(database)/documents/offer/$(offerId)).data.seller_agent_id == request.auth.uid);
        allow update, delete: if false;
      }
    }

    match /offer_payments/{document} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
                     (resource.data.buyer_id == request.auth.uid ||
                      resource.data.agent_id == request.auth.uid);
      allow update, delete: if false;
    }

    match /customers/{document} {
      allow create, read, update, delete: if false;
    }

    match /customers/{parent}/checkout_sessions/{document} {
      allow create, read, update, delete: if false;
    }

    match /customers/{parent}/subscriptions/{document} {
      allow create, read, update, delete: if false;
    }

    match /ff_user_push_notifications/{id} {
      allow read, update, delete: if false;
      allow create: if isSignedIn() &&
                       /databases/$(database)/documents/users/$(request.auth.uid) == request.resource.data.sender;
    }

    // Firestore-triggered email queue
    match /mail/{emailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Firestore-triggered SMS queue
    match /sms_messages/{smsId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Integration telemetry sink (optional diagnostics)
    match /integration_logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
