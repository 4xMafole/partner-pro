rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // ── User sub-collections ──
    match /users/{userId}/favorites/{document} {
      allow create: if request.auth.uid == userId;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    match /users/{userId}/offer/{document} {
      allow read, write: if request.auth.uid == userId;
    }

    match /users/{userId}/suggestions/{document} {
      allow create: if request.auth.uid == userId;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    match /users/{userId}/showami/{document} {
      allow create: if request.auth.uid == userId;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // ── Root-level Favorites ──
    match /favorites/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == resource.data.user_id;
      allow delete: if request.auth.uid == resource.data.user_id;
    }

    // ── Collection group queries for user sub-collections ──
    match /{path=**}/favorites/{document} {
      allow read: if request.auth != null;
    }

    match /{path=**}/suggestions/{document} {
      allow read: if request.auth != null;
    }

    match /{path=**}/showami/{document} {
      allow read: if request.auth != null;
    }

    // ── Properties ──
    match /properties/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Notifications ──
    match /notifications/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // ── Invitations ──
    match /invitations/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Relationships ──
    match /relationships/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Support ──
    match /support/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Saved Searches ──
    match /saved_searches/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Showings ──
    match /showings/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Customers (Stripe) ──
    match /customers/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /customers/{parent}/checkout_sessions/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /{path=**}/checkout_sessions/{document} {
      allow read: if request.auth != null;
    }

    match /customers/{parent}/subscriptions/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/subscriptions/{document} {
      allow read: if request.auth != null;
    }

    // ── Offers (root-level) ──
    match /offer/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // ── Offer Payments ──
    match /offer_payments/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    // ── Push Notifications ──
    match /ff_user_push_notifications/{id} {
      allow read, update, delete: if false;
      allow create: if /databases/$(database)/documents/users/$(request.auth.uid) == request.resource.data.sender;
    }
  }
}
