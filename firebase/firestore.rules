rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /support/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /users/{parent}/favorites/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }

    match /{path=**}/favorites/{document} {
      allow read: if request.auth != null;
    }


    match /users/{parent}/offer/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if request.auth.uid == parent;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }

    match /invitations/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /relationships/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /notifications/{document} {
      allow create: if request.resource.data.user_ref == /databases/$(database)/documents/users/$(request.auth.uid);
      allow read: if resource.data.user_ref == /databases/$(database)/documents/users/$(request.auth.uid);
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /customers/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /customers/{parent}/checkout_sessions/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /{path=**}/checkout_sessions/{document} {
      allow read: if request.auth != null;
    }


    match /customers/{parent}/subscriptions/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/subscriptions/{document} {
      allow read: if true;
    }


    match /offer_payments/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /users/{parent}/suggestions/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }

    match /{path=**}/suggestions/{document} {
      allow read: if request.auth != null;
    }


    match /users/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /users/{parent}/showami/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }

    match /{path=**}/showami/{document} {
      allow read: if request.auth != null;
    }


    match /ff_user_push_notifications/{id} {
      allow read, update, delete: if false;
      allow create: if /databases/$(database)/documents/users/$(request.auth.uid) == request.resource.data.sender;
    }
  }
}
